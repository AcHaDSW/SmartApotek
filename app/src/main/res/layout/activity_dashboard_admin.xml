<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dashboard"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💊 SmartApotek"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Halo Admin, selamat datang kembali 👋"
                android:textSize="14sp"
                android:textColor="#E3F2FD"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- RINGKASAN HARI INI -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="-22dp"
            android:padding="18dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="30dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ringkasan Hari Ini"
                            android:textStyle="bold"
                            android:textSize="22sp"
                            android:textColor="#17325C"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hari Ini"
                            android:textColor="#2F80ED"/>

                    </LinearLayout>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:paddingTop="18dp">

                        <!-- TOTAL OBAT -->

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="160dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="24dp"
                            app:cardBackgroundColor="#F4FFF6">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="💊"
                                    android:textSize="36sp"/>

                                <TextView
                                    android:id="@+id/txtTotalObat"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="30sp"
                                    android:textStyle="bold"
                                    android:textColor="#1FA44A"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Obat"/>

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- STOK -->

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="160dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="24dp"
                            app:cardBackgroundColor="#F3F8FF">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📦"
                                    android:textSize="36sp"/>

                                <TextView
                                    android:id="@+id/txtStok"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="30sp"
                                    android:textStyle="bold"
                                    android:textColor="#1E88E5"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Stok"/>

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- PESANAN -->

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="160dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="24dp"
                            app:cardBackgroundColor="#FFF7E9">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🛒"
                                    android:textSize="36sp"/>

                                <TextView
                                    android:id="@+id/txtPesanan"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="30sp"
                                    android:textStyle="bold"
                                    android:textColor="#FF8F00"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Pesanan"/>

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- VERIFIKASI -->

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="160dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="24dp"
                            app:cardBackgroundColor="#FFF0F7">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="✔"
                                    android:textSize="36sp"/>

                                <TextView
                                    android:id="@+id/txtVerifikasi"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="30sp"
                                    android:textStyle="bold"
                                    android:textColor="#D81B60"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Verifikasi"/>

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </GridLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>


    <!-- MENU ADMIN -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu Admin"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#17325C"/>

        <Button
            android:id="@+id/menuDataObat"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:layout_marginTop="18dp"
            android:text="💊 Kelola Data Obat"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2F80ED"/>

        <Button
            android:id="@+id/menuStok"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:layout_marginTop="12dp"
            android:text="📦 Kelola Stok"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3BB273"/>

        <Button
            android:id="@+id/menuVerifikasi"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:layout_marginTop="12dp"
            android:text="📋 Verifikasi Pesanan"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF8F00"/>

        <Button
            android:id="@+id/menuLaporan"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:layout_marginTop="12dp"
            android:text="📈 Laporan"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B2CBF"/>

    </LinearLayout>
    </LinearLayout>

</ScrollView>