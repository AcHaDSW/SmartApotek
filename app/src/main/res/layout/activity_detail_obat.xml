<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6FAFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:background="@drawable/bg_dashboard"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💊 Detail Obat"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi lengkap obat"
                android:textColor="#EAF6FF"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            android:layout_marginTop="-45dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/txtNamaObat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paracetamol"
                    android:textColor="#17325C"
                    android:textSize="32sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtHarga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/harga_obat"
                    android:textColor="#2F80ED"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"/>

                <!-- STATUS -->

                <TextView
                    android:id="@+id/txtStok"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Stok tersedia"
                    android:textColor="#16A34A"
                    android:textSize="15sp"
                    android:background="#ECFDF3"
                    android:paddingLeft="14dp"
                    android:paddingTop="10dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="10dp"
                    android:layout_marginTop="18dp"/>

                <!-- DESKRIPSI -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deskripsi"
                    android:textColor="#17325C"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="32dp"/>

                <TextView
                    android:id="@+id/txtDeskripsi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Obat digunakan untuk membantu meredakan demam, sakit kepala dan nyeri."
                    android:textColor="#64748B"
                    android:textSize="16sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="12dp"/>

                <!-- BUTTON -->

                <Button
                    android:id="@+id/btnKeranjang"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="28dp"
                    android:text="🛒 Tambah ke Keranjang"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2F80ED"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>