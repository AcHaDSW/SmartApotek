<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:background="@drawable/bg_dashboard"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💊 Detail Obat"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi lengkap obat"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:layout_marginTop="-60dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/imgObat"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="fitCenter"/>

                <TextView
                    android:id="@+id/txtNamaObat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paracetamol"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="#17325C"
                    android:layout_marginTop="16dp"/>
                <TextView
                    android:id="@+id/txtHarga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/harga_obat"
                    android:textColor="#2F80ED"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/txtStok"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Stok tersedia"
                    android:textColor="#16A34A"
                    android:background="#ECFDF3"
                    android:padding="10dp"
                    android:textSize="14sp"
                    android:layout_marginTop="18dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deskripsi"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#17325C"
                    android:layout_marginTop="30dp"/>

                <TextView
                    android:id="@+id/txtDeskripsi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Obat digunakan untuk membantu meredakan demam, sakit kepala dan nyeri."
                    android:textColor="#64748B"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="6dp"/>

                <Button
                    android:id="@+id/btnKeranjang"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="28dp"
                    android:text="Tambah ke Keranjang"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:backgroundTint="#2F80ED"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>