<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F8FC">

    <!-- HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_dashboard">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒 Belanja Obat"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Temukan kebutuhan kesehatanmu"
            android:textColor="#E2E8F0"
            android:layout_marginTop="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/etCari"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FFFFFF"
                android:hint="Cari obat..."
                android:drawableStart="@android:drawable/ic_menu_search"
                android:paddingStart="18dp"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>


    <!-- KATEGORI -->

    <!-- KATEGORI -->

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semua"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Obat Bebas"
                android:layout_marginStart="10dp"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Obat Keras"
                android:layout_marginStart="10dp"/>

        </LinearLayout>

    </HorizontalScrollView>


    <!-- LIST OBAT -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvObat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>